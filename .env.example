# Central StudioFlow control database (separate Neon database recommended)
CONTROL_DATABASE_URL=

# Used only when the control database has no owner account. Remove the password
# from hosting settings after the first successful bootstrap/login.
OWNER_BOOTSTRAP_EMAIL=owner@example.com
OWNER_BOOTSTRAP_PASSWORD=replace-with-at-least-10-characters

# Independent high-entropy values, each at least 24 characters
CONFIG_ENCRYPTION_KEY=replace-with-a-long-random-encryption-key
SESSION_SECRET=replace-with-a-different-long-random-secret

# One shared service account. Every tenant workbook must be shared with this email.
GOOGLE_SERVICE_ACCOUNT_EMAIL=
GOOGLE_SERVICE_ACCOUNT_PRIVATE_KEY=

# Public application URL used in customer/editor portal links
PUBLIC_APP_URL=http://localhost:5173

# Storage warning baseline for each tenant database
DATABASE_STORAGE_LIMIT_MB=500

# One-time legacy Anjana migration only. These create the first tenant when the
# control database has no tenants. Remove them after verifying the migration.
DATABASE_URL=
ADMIN_EMAIL=
ADMIN_PASSWORD=
GOOGLE_SHEETS_ID=
GOOGLE_SHEETS_ORDERS_TAB=Orders
