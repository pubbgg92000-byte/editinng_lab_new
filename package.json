		"svelte-check": "^4.6.0",
		"tailwindcss": "^4.3.0",
		"typescript": "^6.0.3",
		"vite": "^8.0.16",
		"wrangler": "^4.111.0"
	},
	"dependencies": {
		"@neondatabase/serverless": "^1.1.0",
		"exceljs": "^4.4.0",
