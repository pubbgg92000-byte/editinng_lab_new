{
	"name": "editing-lab-new",
	"private": true,
	"version": "0.0.1",
	"type": "module",
	"scripts": {
		"dev": "vite dev",
		"build": "vite build",
		"build:sites": "vite build --config vite.sites.config.ts",
		"preview": "vite preview",
		"prepare": "svelte-kit sync || echo ''",
